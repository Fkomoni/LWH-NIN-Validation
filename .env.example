# Phase 1 — mocked services, no external secrets required yet.
# Flip to "false" in Phase 2 when real integrations land.
NEXT_PUBLIC_MOCKS_ENABLED=true

# Signed-cookie secrets (dev defaults are in code; set these in prod).
# AUTH_SECRET=
# ADMIN_SECRET=
# ADMIN_BOOTSTRAP_PASSWORD=
# OTP_HMAC_SECRET=

# Core DB + KV (Phase 2).
# DATABASE_URL=postgresql://user:pass@host:5432/lwh
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# External integrations (Phase 2). Base URLs currently default to the
# MSW mock hosts; set these to the real provider endpoints in Phase 2.
# NIMC_BASE_URL=
# NIMC_API_KEY=
# PROGNOSIS_BASE_URL=
# PROGNOSIS_CLIENT_ID=
# PROGNOSIS_CLIENT_SECRET=

# Bot protection (Phase 2).
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Messaging (Phase 2).
# RESEND_API_KEY=
# TERMII_API_KEY=

# Observability (Phase 2).
# SENTRY_DSN=
# LOG_LEVEL=info
