# Toggle. "true" = in-memory mocks + MSW (Phase 1 walkthrough).
# Set to "false" on Render when real credentials are provisioned.
NEXT_PUBLIC_MOCKS_ENABLED=true

# When your reverse proxy/CDN does NOT set x-real-ip but appends a
# trusted last hop to X-Forwarded-For, set this to "true" to let the
# middleware fall back to the last hop. Unsafe when the proxy does
# not strip attacker-supplied tail hops.
TRUST_XFF_LAST_HOP=

# Comma-separated absolute origins (scheme + host) permitted to call
# mutating server actions. REQUIRED in production; skipped in dev.
# Example: https://portal.leadwayhealth.com,https://portal-staging.leadwayhealth.com
ALLOWED_ORIGINS=

# ── App-level secrets ──────────────────────────────────────────────────
# Sign auth cookies. Generate with: openssl rand -base64 48
AUTH_SECRET=
ADMIN_SECRET=
OTP_HMAC_SECRET=
# Bootstrap admin password — DEV ONLY, ignored in production.
ADMIN_BOOTSTRAP_PASSWORD=
# Production admin bootstrap credential, scrypt-encoded as
# scrypt$<Nlog2>$<saltB64>$<keyB64>. Generate off-line with
#   node -e "import('./src/lib/secrets').then(m => console.log(m.hashAdminPassword('your-new-password')))"
# REQUIRED in live production; the login flow throws if this is missing.
ADMIN_BOOTSTRAP_PASSWORD_HASH=
# Comma-separated allow-list of admin emails permitted to sign in with
# the bootstrap password. REQUIRED in live production — the login will
# throw at startup if this is empty.
ADMIN_ALLOWED_EMAILS=

# ── Persistence ─────────────────────────────────────────────────────────
# Render Postgres connection string (auto-wired by render.yaml).
DATABASE_URL=

# Upstash Redis (optional — falls back to in-memory KV if absent).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Qore (NIMC provider) ────────────────────────────────────────────────
# QORE_TOKEN_URL is the OAuth token endpoint; QORE_NIN_VERIFY_URL is the
# base URL that the NIN is appended to (e.g. https://api.qoreid.com/ng/nin/).
QORE_TOKEN_URL=
QORE_NIN_VERIFY_URL=
QORE_CLIENT_ID=
QORE_SECRET_KEY=
# Accepted alias (used by the legacy Vite code path): VITE_CORE_SECRET_KEY.
VITE_CORE_SECRET_KEY=

# ── Prognosis (Leadway core) ────────────────────────────────────────────
# Confirmed base: https://prognosis-api.leadwayhealth.com/api
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com/api
PROGNOSIS_USERNAME=
PROGNOSIS_PASSWORD=
# Writes send `Authorization: Bearer <login token>` by default (same
# as reads). Only set these if Leadway ever introduces a gateway that
# needs an additional second header. Setting
# PROGNOSIS_API_KEY_HEADER=Authorization or "none" disables the
# secondary header entirely.
PROGNOSIS_API_KEY=
PROGNOSIS_API_KEY_HEADER=
PROGNOSIS_API_KEY_BEARER=

# ── Bot protection (Phase 2) ────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Observability (Phase 2) ─────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
