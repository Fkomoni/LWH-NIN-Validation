# ====================================================================
# PRODUCTION ENVIRONMENT — lwh-nin-validation
# Paste each value below into Azure App Service → Configuration →
# Application settings. DO NOT commit a populated copy of this file
# anywhere — it contains production secrets.
# ====================================================================

# ── App mode ─────────────────────────────────────────────────────────
# MUST be "false" in production. "true" = in-memory mocks (dev only).
NEXT_PUBLIC_MOCKS_ENABLED=false
NODE_ENV=production

# ── App secrets ──────────────────────────────────────────────────────
# Each is a long random string. Generate three DIFFERENT values with:
#   openssl rand -base64 48
AUTH_SECRET=<fill in — 48+ random chars>
ADMIN_SECRET=<fill in — 48+ random chars>
OTP_HMAC_SECRET=<fill in — 48+ random chars>

# First-login password for the admin console (/admin/login).
# Pick a strong password; change after the first successful login.
ADMIN_BOOTSTRAP_PASSWORD=<fill in — strong password>

# ── Upstash Redis ────────────────────────────────────────────────────
# Required in production. Get these from console.upstash.com → your
# database → REST API tab.
UPSTASH_REDIS_REST_URL=<fill in>
UPSTASH_REDIS_REST_TOKEN=<fill in>

# ── Qore (NIMC verification) ─────────────────────────────────────────
# Supplied by Qore when the account is provisioned.
QORE_TOKEN_URL=<fill in>
QORE_NIN_VERIFY_URL=<fill in>
QORE_CLIENT_ID=<fill in>
QORE_SECRET_KEY=<fill in>

# ── Prognosis (Leadway core API) ─────────────────────────────────────
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com/api
PROGNOSIS_USERNAME=<fill in — Leadway API user>
PROGNOSIS_PASSWORD=<fill in — Leadway API password>

# ── Optional — leave blank unless explicitly told otherwise ──────────
# Qore legacy alias (only if Qore account expects this specific name)
VITE_CORE_SECRET_KEY=

# Prognosis gateway key (only if Leadway later fronts the API with one)
PROGNOSIS_API_KEY=
PROGNOSIS_API_KEY_HEADER=
PROGNOSIS_API_KEY_BEARER=

# Phase-2 extras — bot protection + observability
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SENTRY_DSN=
LOG_LEVEL=info

# Postgres — provisioned for Phase 3; safe to leave blank today
DATABASE_URL=
